# Database
TEXT2SQL_DATABASE_URL=sqlite:///./examples/demo.db
TEXT2SQL_METADATA_DATABASE_URL=sqlite:///./examples/metadata.db

# DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2
DASHSCOPE_RERANK_MODEL=gte-rerank-v2
TEXT2SQL_USE_LLM=0
DASHSCOPE_LLM_MODEL=qwen3.7-plus

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
