{"case_id": "supplier_sales_top5", "query": "销售额最高的5个供应商", "expected_sql": "SELECT suppliers.name AS dimension_value, ROUND(SUM(order_items.subtotal), 2) AS metric_value FROM order_items JOIN skus ON order_items.sku_id = skus.sku_id JOIN spus ON skus.spu_id = spus.spu_id JOIN suppliers ON spus.supplier_id = suppliers.supplier_id GROUP BY suppliers.supplier_id, suppliers.name ORDER BY metric_value DESC LIMIT 5", "expected_tables": ["order_items", "skus", "spus", "suppliers"], "required_sql_keywords": ["join", "sum", "group by"], "allow_clarification": false, "expected_result": [{"dimension_value": "宁波华仓储物流有限公司", "metric_value": 8805222.79}, {"dimension_value": "济南源供应链有限公司", "metric_value": 7665092.12}, {"dimension_value": "重庆宏电子商务有限公司", "metric_value": 6940046.48}, {"dimension_value": "南京源供应链有限公司", "metric_value": 6891699.83}, {"dimension_value": "福州捷贸易有限公司", "metric_value": 6586908.43}]}
